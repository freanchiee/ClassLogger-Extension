{
  "manifest_version": 3,
  "name": "ClassLogger Dev - Teaching Assistant",
  "version": "0.1.0",
  "description": "Automatically log and track your online teaching sessions with Google Meet integration",
  
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "desktopCapture"
  ],
  
  "optional_permissions": [
    "tabCapture"
  ],
  
  "host_permissions": [
    "https://meet.google.com/*",
    "https://classlogger.com/*",
    "http://localhost:3000/*",
    "<all_urls>"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": [
          "modules/config.js",
          "modules/api.js", 
          "modules/auth.js",
          "modules/ui.js",
          "modules/monitoring.js",
          "modules/screenshots.js",
          "modules/timer.js",
          "modules/notes.js",
          "content-script.js"
        ],
      "run_at": "document_end"
    }
  ],
  
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ClassLogger - Teaching Assistant",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png", 
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png", 
    "128": "icons/icon128.png"
  },
  
  "externally_connectable": {
    "matches": ["https://meet.google.com/*"]
  }
}