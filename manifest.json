{
    "manifest_version": 3,
    "name": "ClassLogger - Teaching Assistant",
    "version": "2.1.0",
    "description": "Automatically log and track your online teaching sessions with Google Meet integration, screenshots, and detailed class notes.",
    
    "permissions": [
      "activeTab",
      "storage",
      "tabs",
      "scripting"
    ],
    
    "host_permissions": [
      "https://meet.google.com/*",
      "http://localhost:3000/*",
      "https://*.vercel.app/*"
    ],
    
    "background": {
      "service_worker": "background.js"
    },
    
    "content_scripts": [
      {
        "matches": ["https://meet.google.com/*"],
        "js": ["content-script.js"],
        "run_at": "document_end"
      }
    ],
    
    "action": {
      "default_popup": "popup.html",
      "default_title": "ClassLogger - Teaching Assistant",
      "default_icon": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
      }
    },
    
    "icons": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    
    "web_accessible_resources": [
      {
        "resources": ["icons/*"],
        "matches": ["https://meet.google.com/*"]
      }
    ]
  }